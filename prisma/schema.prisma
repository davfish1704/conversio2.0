generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// AUTH
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  googleId      String?   @unique @map("google_id")
  image         String?
  password      String?
  emailVerified DateTime? @map("email_verified")
  role          UserRole  @default(USER)
  timezone      String?   @default("Europe/Berlin")
  language      String?   @default("de")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   TeamMember[]
  ownedTeams    Team[]        @relation("TeamOwner")
  boardMembers  BoardMember[]
  messages      Message[]     @relation("MessageAuthor")
  assignedLeads Lead[]        @relation("LeadAssignee")

  @@map("users")
}

enum UserRole {
  ADMIN
  USER
  AGENT
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

// ============================================
// TEAMS
// ============================================

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  plan      String   @default("free")
  createdAt DateTime @default(now())

  owner   User         @relation("TeamOwner", fields: [ownerId], references: [id])
  members TeamMember[]
  boards  Board[]

  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

// ============================================
// BOARDS & PIPELINE
// ============================================

model Board {
  id                String           @id @default(cuid())
  teamId            String
  name              String
  description       String?
  isActive          Boolean          @default(true)
  ownerId           String
  adminStatus       BoardAdminStatus @default(ACTIVE)
  ownerStatus       BoardOwnerStatus @default(ACTIVE)
  behaviorMode      String           @default("reactive")
  boardCustomFields Json             @default("[]")
  contextWindowSize Int              @default(20)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  team             Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  states           State[]           @relation("BoardStates")
  members          BoardMember[]
  leads            Lead[]
  conversations    Conversation[]
  reports          AdminReport[]
  brain            BoardBrain?
  assets           BoardAsset[]
  executionLogs    ExecutionLog[]
  brainDocuments   BrainDocument[]
  brainRules       BrainRule[]
  brainFAQs        BrainFAQ[]
  channels         BoardChannel[]
  channelInvites   ChannelInvite[]
  aiProviderConfig AIProviderConfig?

  @@map("boards")
}

enum BoardAdminStatus {
  ACTIVE
  PAUSED
  SUSPENDED
}

enum BoardOwnerStatus {
  ACTIVE
  INACTIVE
  TRIAL
}

model BoardMember {
  id       String    @id @default(cuid())
  boardId  String
  userId   String
  role     BoardRole @default(AGENT)
  joinedAt DateTime  @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@map("board_members")
}

enum BoardRole {
  ADMIN
  AGENT
  VIEWER
}

model State {
  id                      String    @id @default(cuid())
  boardId                 String
  name                    String
  type                    StateType @default(MESSAGE)
  mission                 String?
  rules                   String?
  orderIndex              Int       @default(0)
  isActive                Boolean   @default(true)
  autoTransition          Boolean   @default(false)
  nextStateId             String?
  config                  Json?
  fieldDefinitions        Json?
  behaviorMode            String?
  dataToCollect           Json      @default("[]")
  completionRule          String?
  availableTools          Json      @default("[]")
  escalateOnNoReply       Int?
  escalateOnLowConfidence Boolean   @default(true)
  escalateOnOffMission    Boolean   @default(true)
  maxFollowups            Int       @default(3)
  followupAction          String    @default("escalate")
  followupTargetState     String?
  allowChannelSwitch      Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  board         Board          @relation("BoardStates", fields: [boardId], references: [id], onDelete: Cascade)
  leads         Lead[]         @relation("LeadCurrentState")
  conversations Conversation[] @relation("ConversationCurrentState")

  @@map("states")
}

enum StateType {
  AI
  MESSAGE
  TEMPLATE
  CONDITION
  WAIT
}

// ============================================
// LEADS (CRM-Kontakt)
// ============================================

model Lead {
  id             String   @id @default(cuid())
  boardId        String
  currentStateId String?
  assignedToId   String?
  name           String?
  phone          String?
  email          String?
  avatar         String?
  source         String?  @default("manual")
  channel        String?  @default("whatsapp")
  tags           String[] @default([])
  leadScore      Int      @default(0)
  stateHistory   Json?
  customData     Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  board          Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  currentState   State?          @relation("LeadCurrentState", fields: [currentStateId], references: [id])
  assignedTo     User?           @relation("LeadAssignee", fields: [assignedToId], references: [id])
  conversations  Conversation[]
  memories       LeadMemory[]
  channelInvites ChannelInvite[]

  @@index([boardId, currentStateId])
  @@map("leads")
}

// ============================================
// CONVERSATIONS & NACHRICHTEN
// ============================================

model Conversation {
  id                   String             @id @default(cuid())
  leadId               String
  boardId              String
  currentStateId       String?
  channel              String             @default("whatsapp")
  externalId           String?
  status               ConversationStatus @default(ACTIVE)
  frozen               Boolean            @default(false)
  frozenAt             DateTime?
  frozenReason         String?
  frozenBy             String?
  aiEnabled            Boolean            @default(true)
  followupCount        Int                @default(0)
  conversationSummary  String?
  summaryUpdatedAt     DateTime?
  messageCountSinceSum Int                @default(0)
  customData           Json               @default("{}")
  lastMessageAt        DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  lead          Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  board         Board          @relation(fields: [boardId], references: [id])
  currentState  State?         @relation("ConversationCurrentState", fields: [currentStateId], references: [id])
  messages      Message[]
  executionLogs ExecutionLog[]

  @@index([leadId, lastMessageAt])
  @@index([boardId, status, lastMessageAt])
  @@map("conversations")
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  SPAM
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  authorId       String?
  direction      Direction
  content        String
  mediaUrl       String?
  messageType    MessageType   @default(TEXT)
  status         MessageStatus @default(SENT)
  aiGenerated    Boolean       @default(false)
  externalId     String?
  timestamp      DateTime      @default(now())
  metadata       Json?

  author       User?        @relation("MessageAuthor", fields: [authorId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@map("messages")
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
  LOCATION
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ============================================
// LEAD-GEDÄCHTNIS
// ============================================

model LeadMemory {
  id        String   @id @default(cuid())
  leadId    String
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, key])
  @@index([leadId])
  @@map("lead_memory")
}

// ============================================
// KANÄLE
// ============================================

model BoardChannel {
  id                    String    @id @default(cuid())
  boardId               String
  platform              String
  status                String    @default("disconnected")
  telegramBotToken      String?
  telegramBotUsername   String?
  telegramWebhookSecret String?
  waPhoneNumberId       String?
  waAccessToken         String?
  waBusinessAccountId   String?
  waVerifyToken         String?
  webhookSecret         String?
  igPageId              String?
  igAccessToken         String?
  lastError             String?
  connectedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  board          Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  channelInvites ChannelInvite[]

  @@unique([boardId, platform])
  @@map("board_channels")
}

model ChannelInvite {
  id                     String              @id @default(cuid())
  boardId                String
  leadId                 String
  targetChannelId        String
  token                  String              @unique
  status                 ChannelInviteStatus @default(PENDING)
  createdBy              String?
  reason                 String?
  expiresAt              DateTime
  consumedAt             DateTime?
  consumedConversationId String?
  createdAt              DateTime            @default(now())

  board   Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  lead    Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel BoardChannel @relation(fields: [targetChannelId], references: [id])

  @@index([token])
  @@index([leadId, createdAt])
  @@map("channel_invites")
}

enum ChannelInviteStatus {
  PENDING
  CONSUMED
  EXPIRED
}

// ============================================
// BRAINLAB
// ============================================

model BoardBrain {
  id                    String   @id @default(cuid())
  boardId               String   @unique
  systemPrompt          String   @db.Text
  stylePrompt           String   @db.Text
  infoPrompt            String   @db.Text
  rulePrompt            String   @db.Text
  defaultModel          String   @default("dummy")
  temperature           Float    @default(0.7)
  maxTokens             Int      @default(500)
  language              String   @default("de")
  tone                  String   @default("friendly")
  channelSwitchTemplate String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@map("board_brains")
}

model BoardAsset {
  id        String    @id @default(cuid())
  boardId   String
  type      AssetType
  name      String
  content   String?   @db.Text
  fileUrl   String?
  metadata  Json?
  isActive  Boolean   @default(true)
  tags      String[]
  createdAt DateTime  @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, type])
  @@map("board_assets")
}

enum AssetType {
  AUDIO_MEMO
  PDF_DOC
  IMAGE_ASSET
  TEXT_SNIPPET
  TEMPLATE
  KNOWLEDGE_BASE
}

model BrainDocument {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  content   String   @db.Text
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, category])
  @@map("brain_documents")
}

model BrainRule {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  rule      String   @db.Text
  severity  String   @default("warning")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@map("brain_rules")
}

model BrainFAQ {
  id        String   @id @default(cuid())
  boardId   String
  question  String
  answer    String   @db.Text
  category  String?
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, category])
  @@map("brain_faqs")
}

// ============================================
// MELDUNGEN & ALERTS
// ============================================

model AdminReport {
  id         String      @id @default(cuid())
  boardId    String
  stateId    String?
  type       AlertType
  message    String
  details    String?
  status     AlertStatus @default(OPEN)
  createdAt  DateTime    @default(now())
  resolvedAt DateTime?

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@map("admin_reports")
}

enum AlertType {
  STUCK
  ERROR
  MANUAL_INTERVENTION
  LOOP
  INFO
}

enum AlertStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  IGNORED
}

// ============================================
// AUSFÜHRUNGSPROTOKOLLE
// ============================================

model ExecutionLog {
  id             String          @id @default(cuid())
  boardId        String
  conversationId String
  stateId        String?
  action         String
  input          String?         @db.Text
  output         String?         @db.Text
  context        Json?
  status         ExecutionStatus @default(SUCCESS)
  errorMessage   String?
  stuckDuration  Int?
  needsAttention Boolean         @default(false)
  createdAt      DateTime        @default(now())

  board        Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([boardId, status, createdAt])
  @@map("execution_logs")
}

enum ExecutionStatus {
  SUCCESS
  ERROR
  STUCK
  WAITING_USER
  MANUAL_INTERVENTION
  LOOP
}

// ============================================
// AI-PROVIDER & PLATFORM-SCHLÜSSEL
// ============================================

model AIProviderConfig {
  id               String   @id @default(cuid())
  boardId          String   @unique
  defaultProvider  String   @default("groq")
  defaultModel     String   @default("llama-3.3-70b-versatile")
  fallbackProvider String?
  fallbackModel    String?
  modelOverrides   Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@map("ai_provider_configs")
}

model PlatformAPIKey {
  id                 String   @id @default(cuid())
  provider           String   @unique
  encryptedKey       String
  isActive           Boolean  @default(true)
  monthlyBudgetCents Int?
  createdAt          DateTime @default(now())

  @@map("platform_api_keys")
}

// ============================================
// HINTERGRUND-JOBS
// ============================================

model Job {
  id           String    @id @default(cuid())
  type         String
  payload      Json
  scheduledFor DateTime
  status       JobStatus @default(PENDING)
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  lastError    String?
  leadId       String?
  boardId      String?
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  @@index([status, scheduledFor])
  @@index([leadId])
  @@map("jobs")
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}
