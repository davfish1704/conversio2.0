# Database (Neon.tech PostgreSQL)
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# OAuth (Google)
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# AI (Groq)
GROQ_API_KEY="gsk_..."

# Meta WhatsApp
META_ACCESS_TOKEN="..."
META_PHONE_NUMBER_ID="..."
META_WEBHOOK_VERIFY_TOKEN="..."
# Meta App Secret: Meta Developer Console → App auswählen → App-Einstellungen → Allgemein → App-Geheimnis
META_APP_SECRET="..."

# Nango (OAuth-Integration, optional — nur nötig wenn Nango-Integrationen aktiv)
NANGO_SECRET_KEY="..."
NANGO_HOST="https://api.nango.dev"

# Feature Flags
NEXT_PUBLIC_FEATURE_WHATSAPP="false"
NEXT_PUBLIC_FEATURE_SIGNUP="false"
